generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/simple-store"
}

datasource db {
  provider = "postgresql"
}

// ─── Categories ────────────────────────────────────────────────────────────
model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  icon        String?
  isActive    Boolean   @default(true)
  position    Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@map("categories")
}

// ─── Products ──────────────────────────────────────────────────────────────
model Product {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  shortDesc     String?
  description   String?
  price         Int             // centimes
  originalPrice Int?            // centimes — null si pas de promo
  imageUrl      String?
  previewUrl    String?         // URL d'aperçu gratuit (1er chapitre, extrait vidéo…)
  author        String?
  level         Level           @default(INTERMEDIATE)
  language      String          @default("fr")
  type          ProductType
  isDigital     Boolean         @default(true)
  duration      String?         // "12h30" — formations vidéo
  totalChapters Int?
  totalPages    Int?            // livres
  includes      String[]        // ["Accès à vie", "Mises à jour incluses", "Certificat"]
  tags          String[]
  rating        Float           @default(0)
  reviewCount   Int             @default(0)
  salesCount    Int             @default(0)
  isActive      Boolean         @default(true)
  isFeatured    Boolean         @default(false)
  isNew         Boolean         @default(false)
  isBestseller  Boolean         @default(false)
  categoryId    String
  category      Category        @relation(fields: [categoryId], references: [id])
  formats       ProductFormat[]
  reviews       Review[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([categoryId])
  @@index([isActive, isFeatured])
  @@map("products")
}

enum ProductType {
  FORMATION   // cours vidéo en ligne
  BOOK        // livre (PDF, ebook, papier)
  GUIDE       // guide PDF court
  BUNDLE      // pack formation + livre
  TEMPLATE    // template de code
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

// ─── Formats d'achat ───────────────────────────────────────────────────────
model ProductFormat {
  id              String     @id @default(cuid())
  productId       String
  product         Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  type            FormatType
  label           String     // "PDF", "Broché", "Accès vidéo + PDF", "Pack complet"
  priceAdjustment Int        @default(0) // surcoût en centimes (peut être négatif)
  isDefault       Boolean    @default(false)
  cartItems       CartItem[]
  createdAt       DateTime   @default(now())

  @@unique([productId, type])
  @@map("product_formats")
}

enum FormatType {
  PDF
  EPUB
  PHYSICAL
  VIDEO
  BUNDLE_FORMAT
}

// ─── Reviews ───────────────────────────────────────────────────────────────
model Review {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorName  String
  authorTitle String?  // "Senior Angular Dev", "CTO chez Acme"
  rating      Int      // 1-5
  title       String?
  body        String
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([productId])
  @@map("reviews")
}

// ─── Cart ──────────────────────────────────────────────────────────────────
model Cart {
  id        String     @id @default(cuid())
  sessionId String     @unique
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  expiresAt DateTime?

  @@map("carts")
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  formatId  String?
  format    ProductFormat? @relation(fields: [formatId], references: [id])
  quantity  Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([cartId])
  @@map("cart_items")
}

// ─── Promo codes ───────────────────────────────────────────────────────────
model PromoCode {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?
  discountType   DiscountType
  discountValue  Int
  minOrderAmount Int?
  maxUses        Int?
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)
  expiresAt      DateTime?
  orders         Order[]
  createdAt      DateTime     @default(now())

  @@map("promo_codes")
}

enum DiscountType {
  PERCENT
  FIXED_AMOUNT
}

// ─── Orders ────────────────────────────────────────────────────────────────
model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  accessCode      String      @unique // code d'accès aux achats digitaux
  status          OrderStatus @default(PENDING)

  customerEmail     String
  customerFirstName String
  customerLastName  String
  customerPhone     String?

  // Shipping — optionnel, seulement pour produits physiques
  hasPhysicalItems      Boolean @default(false)
  shippingLine1         String?
  shippingLine2         String?
  shippingCity          String?
  shippingZip           String?
  shippingCountry       String?
  shippingMethod        String?
  carrier               String?
  trackingNumber        String?

  subtotal        Int
  discountAmount  Int         @default(0)
  shippingAmount  Int         @default(0)
  total           Int

  promoCodeId       String?
  promoCode         PromoCode? @relation(fields: [promoCodeId], references: [id])
  promoCodeSnapshot String?

  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?

  paidAt       DateTime?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?

  items     OrderItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([customerEmail])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName  String   // snapshot
  productImage String?
  formatLabel  String?  // snapshot du format acheté
  isDigital    Boolean  @default(true)
  downloadUrl  String?  // généré après paiement
  accessExpiresAt DateTime? // null = accès à vie
  unitPrice    Int
  quantity     Int
  totalPrice   Int
  createdAt    DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}

model StripeWebhookEvent {
  id String @id
  @@map("stripe_webhook_events")
}
